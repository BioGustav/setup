alias c="clear"
alias cat="bat"
alias ls="ls --color"
alias l="ls -lAh"
alias z="zoxide query"

# dnf
alias s="dnf search"
alias i="sudo dnf install"
alias r="sudo dnf remove"
alias u="sudo dnf upgrade --refresh && flatpak upgrade"
alias uy="sudo dnf upgrade --refresh -y && flatpak upgrade -y"

# clipboard
alias clipboard="xclip -selection clipboard"
alias cclip="xclip -rmlastnl -selection clipboard"
alias pclip="xclip -out -selection clipboard"

# nvim
alias vim=nvim

# docker
alias up="docker compose up -d"
alias down="docker compose down && docker rmi \$(docker images -q)"